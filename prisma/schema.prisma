// Sofra control plane — partner program v1 (SOFRA-PARTNER-PLAN.md).
// Prisma 7: no Rust engine; runtime goes through @prisma/adapter-pg (see lib/db.ts).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PARTNER
  // Direct restaurant owner (ADR-004 self-serve): pays for their own tenant, no
  // reseller relationship. Onboarded from a signup lead; dashboard = own plan only.
  OWNER
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SignupStatus {
  NEW
  CONTACTED
  CONVERTED
  DECLINED
}

enum ClientStatus {
  LEAD
  CONTACTED
  DEMO_SCHEDULED
  AGREED
  ONBOARDING
  LIVE
  CHURNED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?
  name         String
  role         UserRole   @default(PARTNER)
  status       UserStatus @default(INVITED)
  createdAt    DateTime   @default(now())

  profile      PartnerProfile?
  clients      Client[]
  notes        ClientNote[]
  commissions  CommissionEntry[]   @relation("PartnerCommissions")
  createdEntries CommissionEntry[] @relation("EntryAuthor")
  inviteTokens InviteToken[]
  auditLogs    AuditLog[]
  // Tenants this user pays for directly (OWNER self-serve; ADR-004).
  billingsPaid TenantBilling[]     @relation("BillingPayer")
}

model PartnerApplication {
  id        String            @id @default(cuid())
  name      String
  email     String
  company   String?
  city      String?
  message   String
  locale    String            @default("en")
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  decidedAt DateTime?

  @@index([status, createdAt])
}

// Direct (non-partner) restaurant signup intake (ADR-004 self-serve v1). A
// public form drops a NEW row + founder email; conversion stays founder-operated
// via /admin/onboard until the auto-provisioning hook lands. Mirrors
// PartnerApplication (a lead queue, not a User/Client yet).
model SignupRequest {
  id             String       @id @default(cuid())
  restaurantName String
  contactName    String
  email          String
  phone          String?
  city           String?
  desiredSlug    String?
  message        String?
  locale         String       @default("en")
  status         SignupStatus @default(NEW)
  createdAt      DateTime     @default(now())
  decidedAt      DateTime?

  @@index([status, createdAt])
}

model PartnerProfile {
  userId  String  @id
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company String?
  phone   String?
  city    String?
  // Founder-only notes — never rendered in partner-facing views.
  notes   String?
}

model Client {
  id             String       @id @default(cuid())
  partnerId      String
  partner        User         @relation(fields: [partnerId], references: [id])
  restaurantName String
  contactName    String?
  email          String?
  phone          String?
  city           String?
  status         ClientStatus @default(LEAD)
  // Set by ADMIN only, after founder-operated provisioning (ADR-003/006).
  // Unique: two LIVE clients must never share a tenant.
  tenantSlug     String?      @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  clientNotes ClientNote[]
  commissions CommissionEntry[]
  billing     TenantBilling?

  @@index([partnerId, status])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
}

model CommissionEntry {
  id          String   @id @default(cuid())
  partnerId   String
  partner     User     @relation("PartnerCommissions", fields: [partnerId], references: [id])
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  amountCents Int
  // Sofra's books are EUR (NL company; flipped from CHF 2026-07-06 — the
  // stale CHF default is corrected in the mollie_billing migration).
  currency    String   @default("EUR")
  note        String
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("EntryAuthor", fields: [createdById], references: [id])

  @@index([partnerId, createdAt])
}

// --- Mollie subscription billing (S9 — ADR-005, ADR-011 Job A) -------------
// Sofra bills its tenants: one TenantBilling per tenant (keyed by the
// registry slug, optionally linked to the partner-CRM Client), holding the
// Mollie customer. Money is integer cents + explicit currency (EUR).
// Mollie is the source of truth for payment state — rows here are the local
// mirror, updated only from API re-fetches (never from raw webhook bodies).

enum SubscriptionStatus {
  PENDING // plan defined; waiting for the first payment to create the mandate
  ACTIVATING // claimed by a webhook worker; Mollie call in flight (self-heals)
  ACTIVE // subscription created at Mollie and charging
  CANCELED
  SUSPENDED
  COMPLETED
}

model TenantBilling {
  id               String   @id @default(cuid())
  // Registry slug (deploy repo tenants/registry.yml) — the billing anchor;
  // not a FK on purpose (the registry graduates to a table only at >3
  // tenants, ADR-007).
  tenantSlug       String   @unique
  name             String
  email            String
  // Null until the payer starts the first payment: an admin can define a
  // PENDING plan (partner onboarding) before any Mollie customer exists. The
  // @unique still holds — Postgres allows multiple NULLs.
  mollieCustomerId String?  @unique
  clientId         String?  @unique
  client           Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  // Explicit payer for the direct-owner flow (ADR-004): set when there is no
  // reseller Client. The reseller flow leaves this null and derives the payer
  // from client.partner. Exactly one of clientId / payerUserId is set in practice.
  payerUserId      String?
  payer            User?    @relation("BillingPayer", fields: [payerUserId], references: [id], onDelete: SetNull)
  // Display-only: when the tenant's app went live (admin-entered at
  // onboarding), shown on the partner's welcome panel.
  liveSince        DateTime?
  createdAt        DateTime @default(now())

  subscriptions BillingSubscription[]
  payments      BillingPayment[]

  @@index([payerUserId])
}

model BillingSubscription {
  id                   String             @id @default(cuid())
  billingId            String
  billing              TenantBilling      @relation(fields: [billingId], references: [id], onDelete: Cascade)
  // Set when the subscription is created at Mollie (after the first payment
  // validates the mandate); null while PENDING.
  mollieSubscriptionId String?            @unique
  description          String
  amountCents          Int
  currency             String             @default("EUR")
  interval             String             @default("1 month") // Mollie grammar
  status               SubscriptionStatus @default(PENDING)
  startDate            DateTime?
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())

  @@index([billingId, createdAt])
}

model BillingPayment {
  id                   String        @id @default(cuid())
  billingId            String
  billing              TenantBilling @relation(fields: [billingId], references: [id], onDelete: Cascade)
  molliePaymentId      String        @unique
  mollieSubscriptionId String?
  amountCents          Int
  currency             String        @default("EUR")
  description          String
  status               String // Mollie statuses verbatim: open|pending|paid|failed|canceled|expired|authorized
  sequenceType         String // first | recurring | oneoff
  method               String?
  // Hosted-checkout URL — only meaningful while status is open/pending.
  checkoutUrl          String?
  paidAt               DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([billingId, createdAt])
}

// Set-password invites and password resets. Token stored hashed, single-use.
model InviteToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  purpose   String    @default("invite") // "invite" | "reset"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String?
  entityId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
